// ───────────────────── Skill 53: repurchase + scent wardrobe ─────────────────────

model ScentWardrobe {
  id        String              @id @default(cuid())
  userId    String              @unique
  name      String              @default("我的香味衣橱")
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  items     ScentWardrobeItem[]

  @@map("scent_wardrobes")
}

model ScentWardrobeItem {
  id             String        @id @default(cuid())
  wardrobeId     String
  productId      String
  role           String
  source         String        @default("manual")
  usageFrequency String?
  note           String?
  createdAt      DateTime      @default(now())
  wardrobe       ScentWardrobe @relation(fields: [wardrobeId], references: [id], onDelete: Cascade)

  @@index([wardrobeId])
  @@map("scent_wardrobe_items")
}

model RepurchaseReminder {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  orderId      String?
  reminderType String
