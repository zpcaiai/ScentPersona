generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QuizSession {
  id                        String        @id @default(cuid())
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  source                    String?
  userAgent                 String?
  personaId                 String?
  tagScoresJson             String        @default("{}")
  recommendedProductIdsJson String        @default("[]")
  completedAt               DateTime?
  answers                   QuizAnswer[]

  @@map("quiz_sessions")
}

model QuizAnswer {
  id            String      @id @default(cuid())
  sessionId     String
  questionId    String
  optionId      String
  tagScoresJson String      @default("{}")
  createdAt     DateTime    @default(now())
  session       QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

model PurchaseIntent {
  id              String      @id @default(cuid())
  sessionId       String?
  productType     String
  productIdsJson  String      @default("[]")
  price           Int
  status          String      @default("created")
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  note            String?
  createdAt       DateTime    @default(now())

  @@map("purchase_intents")
}

model Feedback {
  id                  String      @id @default(cuid())
  sessionId           String?
  purchaseIntentId    String?
  personaId           String?
  favoriteProductId   String?
  dislikedProductIdsJson String    @default("[]")
  ratingsJson         String      @default("{}")
  comment             String?
  boughtFullSize      Boolean     @default(false)
  fullSizeProductId   String?
  createdAt           DateTime    @default(now())

  @@map("feedbacks")
}

model AdminMetricSnapshot {
  id                  String   @id @default(cuid())
  date                DateTime @default(now())
  visits              Int      @default(0)
  quizStarts          Int      @default(0)
  quizCompletions     Int      @default(0)
  purchaseIntents     Int      @default(0)
  feedbackSubmissions Int      @default(0)
  fullSizeConversions Int      @default(0)

  @@map("admin_metric_snapshots")
}
