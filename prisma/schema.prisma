}

model OrderContractSnapshot {
  id                   String   @id @default(cuid())
  orderId              String
  legalDocumentType    String
  legalDocumentVersion String
  acceptedAt           DateTime @default(now())
  acceptedIp           String?
  acceptedUserAgent    String?
  contentSnapshot      String
  createdAt            DateTime @default(now())

  @@index([orderId])
  @@map("order_contract_snapshots")
}

model InvoiceRequest {
  id          String    @id @default(cuid())
  userId      String?
  orderId     String
  invoiceType String    @default("personal")
  title       String
  taxNo       String?
  email       String
  amountCents Int
  status      String    @default("requested")
  issuedAt    DateTime?
  invoiceUrl  String?
  note        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([orderId])
  @@index([userId])
  @@map("invoice_requests")
}

// ───────────────────── Skill 42: offer trust score ─────────────────────

model ProductOfferTrustScore {
  id                       String   @id @default(cuid())
  productOfferId           String   @unique
  score                    Int
