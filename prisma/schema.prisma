  @@map("cosmetic_compliance_checks")
}

// ───────────────────── Skill 44: after-sales evidence + anti-fraud ─────────────────────

model AfterSalesCase {
  id              String              @id @default(cuid())
  caseNo          String              @unique
  orderId         String
  userId          String?
  type            String
  status          String              @default("submitted")
  riskScore       Int                 @default(0)
  riskFlagsJson   String              @default("[]")
  userDescription String
  adminConclusion String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  closedAt        DateTime?
  evidence        AfterSalesEvidence[]

  @@index([orderId])
  @@index([status])
  @@map("after_sales_cases")
}

model AfterSalesEvidence {
  id           String         @id @default(cuid())
  caseId       String
  evidenceType String
  fileUrl      String?
  text         String?
  metadataJson String         @default("{}")
  uploadedBy   String         @default("user")
  createdAt    DateTime       @default(now())
  case         AfterSalesCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("after_sales_evidence")
}

model UserRiskFlag {
  id        String   @id @default(cuid())
  userId    String?
  phoneHash String?
  riskType  String
  reason    String
  severity  String   @default("low")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([phoneHash])
  @@map("user_risk_flags")
}

model OrderRiskFlag {
  id        String   @id @default(cuid())
  orderId   String
  riskType  String
  reason    String
  severity  String   @default("low")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_risk_flags")
}

// ───────────────────── Skill 45: risk rules + assessments ─────────────────────

model RiskRule {
  id        String   @id @default(cuid())
  name      String
  type      String
  ruleJson  String   @default("{}")
  severity  String   @default("medium")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("risk_rules")
}

model RiskAssessment {
  id            String   @id @default(cuid())
  targetType    String
  targetId      String
  score         Int
  level         String
  riskFlagsJson String   @default("[]")
  reasonsJson   String   @default("[]")
  createdAt     DateTime @default(now())

  @@index([targetType, targetId])
  @@map("risk_assessments")
}

model ManualRiskReview {
  id           String    @id @default(cuid())
  assessmentId String
  status       String    @default("pending")
  reviewedBy   String?
  reviewNote   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([assessmentId])
  @@map("manual_risk_reviews")
}

// ───────────────────── Skill 46: support tickets ─────────────────────

model SupportTicket {
  id            String          @id @default(cuid())
  ticketNo      String          @unique
  userId        String?
  orderId       String?
  category      String
  priority      String          @default("normal")
  status        String          @default("open")
  subject       String
  latestMessage String?
  assignedTo    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  closedAt      DateTime?
  messages      SupportMessage[]

  @@index([status])
  @@index([userId])
  @@map("support_tickets")
}

model SupportMessage {
  id              String        @id @default(cuid())
  ticketId        String
  senderType      String
  senderId        String?
  message         String
  attachmentsJson String        @default("[]")
  createdAt       DateTime      @default(now())
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("support_messages")
}

model SupportTemplate {
  id        String   @id @default(cuid())
  category  String
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("support_templates")
}

// ───────────────────── Skill 47: notifications ─────────────────────

model Notification {
  id           String            @id @default(cuid())
  userId       String?
  sessionId    String?
  orderId      String?
  channel      String            @default("in_app")
  type         String
  title        String
  content      String
  status       String            @default("pending")
  scheduledAt  DateTime?
  sentAt       DateTime?
  readAt       DateTime?
  metadataJson String            @default("{}")
  createdAt    DateTime          @default(now())
  logs         NotificationLog[]

  @@index([userId, status])
  @@index([orderId])
  @@map("notifications")
}

model NotificationTemplate {
  id              String   @id @default(cuid())
  type            String
  channel         String
  titleTemplate   String
  contentTemplate String
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([type, channel])
  @@map("notification_templates")
}

model NotificationPreference {
  id        String   @id @default(cuid())
  userId    String
  channel   String
  type      String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, channel, type])
  @@map("notification_preferences")
}

model NotificationLog {
  id                String       @id @default(cuid())
  notificationId    String
  provider          String
  providerMessageId String?
  status            String
  errorMessage      String?
  rawDataJson       String       @default("{}")
  createdAt         DateTime     @default(now())
  notification      Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_logs")
}

// ───────────────────── Skill 48: self-op sample inventory ─────────────────────

model InventorySku {
  id                String          @id @default(cuid())
  skuCode           String          @unique
  name              String
  productId         String?
  type              String
  volumeMl          Int?
  batchNo           String?
  expirationDate    DateTime?
  stockQuantity     Int             @default(0)
  reservedQuantity  Int             @default(0)
  availableQuantity Int             @default(0)
  costCents         Int             @default(0)
  status            String          @default("active")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  movements         StockMovement[]

  @@map("inventory_skus")
}

model StockMovement {
  id             String       @id @default(cuid())
  skuId          String
  type           String
  quantity       Int
  reason         String
  relatedOrderId String?
  createdBy      String?
  createdAt      DateTime     @default(now())
  sku            InventorySku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([skuId, createdAt])
  @@map("stock_movements")
}

model SampleKit {
  id                  String   @id @default(cuid())
  name                String
  kitType             String
  priceCents          Int
  includedSkuRulesJson String  @default("[]")
  status              String   @default("active")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("sample_kits")
}

model KitAssemblyOrder {
  id        String   @id @default(cuid())
  orderId   String
  kitId     String
  status    String   @default("pending")
  itemsJson String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@map("kit_assembly_orders")
}

// ───────────────────── Skill 49: pick / pack / ship ─────────────────────

model FulfillmentOrder {
  id            String            @id @default(cuid())
  orderId       String
  fulfillmentNo String            @unique
  type          String
  status        String            @default("pending")
  warehouse     String?
  assignedTo    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         FulfillmentItem[]
  packingSlip   PackingSlip?

  @@index([orderId])
  @@index([status])
  @@map("fulfillment_orders")
}

model FulfillmentItem {
  id                 String           @id @default(cuid())
  fulfillmentOrderId String
  skuId              String?
  skuName            String
  quantity           Int
  pickedQuantity     Int              @default(0)
  status             String           @default("pending")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  fulfillmentOrder   FulfillmentOrder @relation(fields: [fulfillmentOrderId], references: [id], onDelete: Cascade)

  @@index([fulfillmentOrderId])
  @@map("fulfillment_items")
}

model PackingSlip {
  id                 String           @id @default(cuid())
  fulfillmentOrderId String           @unique
  slipNo             String
  contentJson        String           @default("{}")
  printedAt          DateTime?
  createdAt          DateTime         @default(now())
  fulfillmentOrder   FulfillmentOrder @relation(fields: [fulfillmentOrderId], references: [id], onDelete: Cascade)

  @@map("packing_slips")
}

// ───────────────────── Skill 50: content CMS / landing pages ─────────────────────

model ContentPage {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  subtitle         String?
  pageType         String    @default("landing")
  status           String    @default("draft")
  heroImageUrl     String?
  heroThumbUrl     String?
  contentBlocksJson String   @default("[]")
  seoTitle         String?
  seoDescription   String?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status])
  @@map("content_pages")
}

model Campaign {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  source        String?
  medium        String?
  landingPageId String?
  startAt       DateTime?
  endAt         DateTime?
  status        String    @default("active")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("campaigns")
}

// ───────────────────── Skill 51: coupons / referral / membership ─────────────────────

model Coupon {
  id                String              @id @default(cuid())
  code              String              @unique
  type              String
  value             Int
  minOrderAmountCents Int?
  maxDiscountCents  Int?
  scope             String              @default("all")
  startsAt          DateTime?
  expiresAt         DateTime?
  usageLimit        Int?
  perUserLimit      Int?
  usedCount         Int                 @default(0)
  status            String              @default("active")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  redemptions       CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id           String   @id @default(cuid())
  couponId     String
  userId       String?
  orderId      String?
  discountCents Int
  redeemedAt   DateTime @default(now())
  coupon       Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemptions")
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  status    String   @default("active")
  createdAt DateTime @default(now())

  @@map("referral_codes")
}

model ReferralReward {
  id              String   @id @default(cuid())
  referrerUserId  String
  referredUserId  String?
  referralCode    String
  rewardType      String
  rewardValue     Int
  status          String   @default("pending")
  createdAt       DateTime @default(now())

  @@index([referrerUserId])
  @@map("referral_rewards")
}

model MembershipTier {
  id          String   @id @default(cuid())
  name        String
  level       Int      @unique
  benefitsJson String  @default("[]")
  minSpendCents Int
  createdAt   DateTime @default(now())

  @@map("membership_tiers")
}

model UserMembership {
  id             String   @id @default(cuid())
  userId         String   @unique
  tierId         String?
  points         Int      @default(0)
  totalSpendCents Int     @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_memberships")
}

