  productId         String    @unique
  productOfferId    String?
  checkStatus       String    @default("pending")
  filingNo          String?
  manufacturer      String?
  importer          String?
  originCountry     String?
  ingredientListJson String   @default("[]")
  allergenNotice    String?
  batchNo           String?
  shelfLife         String?
