generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model QuizSession {
  id                        String        @id @default(cuid())
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt
  source                    String?
  userAgent                 String?
  personaId                 String?
  tagScoresJson             String        @default("{}")
  recommendedProductIdsJson String        @default("[]")
  completedAt               DateTime?
  answers                   QuizAnswer[]

  @@map("quiz_sessions")
}

model QuizAnswer {
  id            String      @id @default(cuid())
  sessionId     String
  questionId    String
  optionId      String
  tagScoresJson String      @default("{}")
  createdAt     DateTime    @default(now())
  session       QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("quiz_answers")
}

model PurchaseIntent {
  id              String      @id @default(cuid())
  sessionId       String?
  productType     String
  productIdsJson  String      @default("[]")
  price           Int
  status          String      @default("created")
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  note            String?
  createdAt       DateTime    @default(now())

  @@map("purchase_intents")
}

model Feedback {
  id                  String      @id @default(cuid())
  sessionId           String?
  purchaseIntentId    String?
  orderId             String?
  personaId           String?
  favoriteProductId   String?
  dislikedProductIdsJson String    @default("[]")
  ratingsJson         String      @default("{}")
  comment             String?
  boughtFullSize      Boolean     @default(false)
  fullSizeProductId   String?
  createdAt           DateTime    @default(now())

  @@map("feedbacks")
}

// Unified order model. orderType discriminates between the existing
// "sample_kit" purchase flow and the new "proxy" (代下单) fulfillment flow.
// Sample-kit orders keep using their original columns; proxy orders use the
// snapshot/quote columns plus the related Order* tables below.
model Order {
  id              String    @id @default(cuid())
  orderNo         String    @unique
  accessToken     String    @unique
  orderType       String    @default("sample_kit")
  userId          String?
  sessionId       String?
  productType     String
  productIdsJson  String    @default("[]")
  amount          Int
  status          String    @default("pending")
  platform        String    @default("weapp")
  prepayId        String?
  transactionId   String?
  customerName    String
  customerPhone   String
  shippingAddress String?
  trackingNumber  String?
  note            String?

  // --- proxy-order product snapshot ---
  sourcePlatform          String?
  sourceOfferId           String?
  sourceProductUrl        String?
  productTitle            String?
  productImageUrl         String?
  productBrand            String?
  productSpec             String?
  quantity                Int      @default(1)

  // --- proxy-order money breakdown (cents) ---
  productPriceCents        Int?
  serviceFeeCents          Int?
  domesticShippingFeeCents Int?
  estimatedTotalCents      Int?
  finalTotalCents          Int?
  currency                 String  @default("CNY")

  // --- proxy-order quote / risk ---
  quoteExpiresAt    DateTime?
  priceSnapshotJson String    @default("{}")
  riskFlagsJson     String    @default("[]")
  userNote          String?
  adminNote         String?

  paidAt          DateTime?
  shippedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  address          OrderAddress?
  purchase         OrderPurchase?
  shipment         OrderShipment?
  payments         OrderPayment[]
  refunds          OrderRefund[]
  priceAdjustments OrderPriceAdjustment[]
  events           OrderEvent[]

  @@index([orderType, status])
  @@index([userId])
  @@map("orders")
}

model OrderAddress {
  id                  String   @id @default(cuid())
  orderId             String   @unique
  recipientName       String
  phone               String
  province            String
  city                String
  district            String
  addressLine1        String
  addressLine2        String?
  postalCode          String?
  encryptedRawAddress String?
  createdAt           DateTime @default(now())
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_addresses")
}

model OrderPayment {
  id                  String        @id @default(cuid())
  orderId             String
  provider            String
  providerPaymentId   String?
  status              String        @default("created")
  purpose             String        @default("order")
  amountCents         Int
  currency            String        @default("CNY")
  paidAt              DateTime?
  refundedAmountCents Int           @default(0)
  rawDataJson         String        @default("{}")
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds             OrderRefund[]

  @@index([orderId])
  @@index([provider, providerPaymentId])
  @@map("order_payments")
}

model OrderPurchase {
  id                   String    @id @default(cuid())
  orderId              String    @unique
  platform             String
  platformOrderNo      String?
  purchaseAccountLabel String?
  purchaseStatus       String    @default("pending")
  purchasedAt          DateTime?
  purchaseCostCents    Int?
  screenshotUrl        String?
  rawDataJson          String    @default("{}")
  adminNote            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  order                Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_purchases")
}

model OrderShipment {
  id                 String    @id @default(cuid())
  orderId            String    @unique
  carrierCode        String?
  carrierName        String?
  trackingNo         String?
  shippingStatus     String    @default("pending")
  shippedAt          DateTime?
  deliveredAt        DateTime?
  latestTrackingText String?
  trackingRawJson    String    @default("{}")
  lastSyncedAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  order              Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_shipments")
}

model OrderRefund {
  id               String        @id @default(cuid())
  orderId          String
  paymentId        String?
  status           String        @default("requested")
  reason           String
  amountCents      Int
  providerRefundId String?
  processedAt      DateTime?
  rawDataJson      String        @default("{}")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  order            Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment          OrderPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_refunds")
}

model OrderPriceAdjustment {
  id            String    @id @default(cuid())
  orderId       String
  oldTotalCents Int
  newTotalCents Int
  diffCents     Int
  reason        String
  status        String    @default("pending")
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, status])
  @@map("order_price_adjustments")
}

model OrderEvent {
  id           String   @id @default(cuid())
  orderId      String
  eventType    String
  fromStatus   String?
  toStatus     String?
  title        String
  message      String?
  operatorId   String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("order_events")
}

model AdminMetricSnapshot {
  id                  String   @id @default(cuid())
  date                DateTime @default(now())
  visits              Int      @default(0)
  quizStarts          Int      @default(0)
  quizCompletions     Int      @default(0)
  purchaseIntents     Int      @default(0)
  feedbackSubmissions Int      @default(0)
  fullSizeConversions Int      @default(0)

  @@map("admin_metric_snapshots")
}

model DataDeletionRequest {
  id          String   @id @default(cuid())
  userId      String?
  contact    String
  identifier String
  reason     String?
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@map("data_deletion_requests")
}

model Product {
  id                 String       @id @default(cuid())
  normalizedName     String
  brand              String?
  mainImageUrl       String?
  category           String?      @default("fragrance")
  concentration      String?
  volumeMl           Int?
  gender             String?
  scentFamily        String?
  topNotesJson       String       @default("[]")
  middleNotesJson    String       @default("[]")
  baseNotesJson      String       @default("[]")
  scentTagsJson      String       @default("{}")
  suitableScenesJson String       @default("[]")
  reviewStatus       String       @default("pending")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  offers             ProductOffer[]
  matchCandidates    ProductMatchCandidate[]
  events             UserProductEvent[]

  @@index([normalizedName])
  @@index([brand])
  @@map("catalog_products")
}

model ProductOffer {
  id                 String       @id @default(cuid())
  productId          String
  platform           String
  platformProductId  String?
  title              String
  brand              String?
  shopName           String?
  shopType           String?
  priceCents         Int?
  originalPriceCents Int?
  currency           String       @default("CNY")
  rating             Float?
  reviewCount        Int?
  salesCount         Int?
  imageUrl           String?
  sourceUrl          String
  affiliateUrl       String?
  couponInfoJson     String       @default("{}")
  rawDataJson        String       @default("{}")
  riskFlagsJson      String       @default("[]")
  qualityScore       Int          @default(0)
  reviewStatus       String       @default("needs_review")
  fetchedAt          DateTime
  isAvailable        Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  product            Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  priceHistory       PriceHistory[]
  matchCandidates    ProductMatchCandidate[]
  events             UserProductEvent[]

  @@unique([platform, platformProductId])
  @@index([platform, fetchedAt])
  @@index([productId])
  @@map("product_offers")
}

model ProductSource {
  id           String   @id @default(cuid())
  platform     String
  sourceType   String
  query        String?
  status       String   @default("idle")
  lastRunAt    DateTime?
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([platform, sourceType])
  @@map("product_sources")
}

model PriceHistory {
  id                 String       @id @default(cuid())
  productOfferId     String
  priceCents         Int?
  originalPriceCents Int?
  couponInfoJson     String       @default("{}")
  fetchedAt          DateTime
  productOffer       ProductOffer @relation(fields: [productOfferId], references: [id], onDelete: Cascade)

  @@index([productOfferId, fetchedAt])
  @@map("price_history")
}

model ProductMatchCandidate {
  id             String       @id @default(cuid())
  productId      String
  productOfferId String
  matchScore     Int
  matchReason    String
  status         String       @default("pending")
  createdAt      DateTime     @default(now())
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productOffer   ProductOffer @relation(fields: [productOfferId], references: [id], onDelete: Cascade)

  @@index([productId, status])
  @@map("product_match_candidates")
}

model ProductSyncJob {
  id           String    @id @default(cuid())
  type         String
  platform     String?
  query        String?
  status       String    @default("pending")
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  resultJson   String    @default("{}")
  createdAt    DateTime  @default(now())

  @@index([type, status, createdAt])
  @@map("product_sync_jobs")
}

model UserProductEvent {
  id             String        @id @default(cuid())
  sessionId      String?
  productId      String?
  productOfferId String?
  eventType      String
  eventValueJson String        @default("{}")
  createdAt      DateTime      @default(now())
  product        Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  productOffer   ProductOffer? @relation(fields: [productOfferId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([sessionId])
  @@index([productId])
  @@map("user_product_events")
}

model AnalyticsEvent {
  id           String   @id @default(cuid())
  eventName    String
  source       String?
  path         String?
  sessionId    String?
  orderId      String?
  personaId    String?
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  @@index([eventName, createdAt])
  @@index([sessionId])
  @@index([orderId])
  @@map("analytics_events")
}

// ───────────────────────────── Commercial Batch 1 ─────────────────────────────
// Skill 38: user accounts + scent asset center

model User {
  id           String                @id @default(cuid())
  email        String?               @unique
  phone        String?               @unique
  displayName  String?
  avatarUrl    String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  profile      UserProfile?
  scentProfile UserScentProfile?
  addresses    UserAddress[]
  favorites    UserFavoriteProduct[]
  consents     PrivacyConsent[]

  @@map("users")
}

model UserProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  gender                  String?
  birthday                DateTime?
  preferredBudgetMinCents Int?
  preferredBudgetMaxCents Int?
  favoriteScenesJson      String   @default("[]")
  dislikedScentTagsJson   String   @default("[]")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model UserAddress {
  id            String   @id @default(cuid())
  userId        String
  recipientName String
  phone         String
  province      String
  city          String
  district      String
  addressLine1  String
  addressLine2  String?
  postalCode    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

model UserScentProfile {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  currentPersonaId       String?
  scentScoresJson        String   @default("{}")
  likedProductIdsJson    String   @default("[]")
  dislikedProductIdsJson String   @default("[]")
  likedTagsJson          String   @default("[]")
  dislikedTagsJson       String   @default("[]")
  lastQuizSessionId      String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_scent_profiles")
}

model UserFavoriteProduct {
  id             String   @id @default(cuid())
  userId         String
  productId      String
  productOfferId String?
  note           String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@map("user_favorite_products")
}

// Skill 39: order profit accounting

model OrderProfitSnapshot {
  id                       String   @id @default(cuid())
  orderId                  String
  orderType                String
  revenueCents             Int
  productCostCents         Int
  serviceFeeRevenueCents   Int
  shippingRevenueCents     Int
  shippingCostCents        Int
  paymentFeeCents          Int
  couponCostCents          Int
  refundCostCents          Int
  laborCostCents           Int
  affiliateCommissionCents Int
  grossProfitCents         Int
  netProfitCents           Int
  grossMargin              Float
  netMargin                Float
  profitStatus             String   @default("complete")
  calculatedAt             DateTime @default(now())
  metadataJson             String   @default("{}")

  @@index([orderId, calculatedAt])
  @@map("order_profit_snapshots")
}

model CostRule {
  id        String   @id @default(cuid())
  name      String
  type      String
  ruleJson  String   @default("{}")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cost_rules")
}

// Skill 41: privacy consent + data access audit + admin RBAC

model PrivacyConsent {
  id          String    @id @default(cuid())
  userId      String?
  sessionId   String?
  consentType String
  version     String
  acceptedAt  DateTime  @default(now())
  revokedAt   DateTime?
  ip          String?
  userAgent   String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("privacy_consents")
}

model DataAccessLog {
  id           String   @id @default(cuid())
  adminUserId  String?
  targetUserId String?
  resourceType String
  resourceId   String
  action       String
  fieldsJson   String   @default("[]")
  reason       String?
  createdAt    DateTime @default(now())

  @@index([resourceType, resourceId])
  @@index([adminUserId, createdAt])
  @@map("data_access_logs")
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  role         String    @default("operator")
  status       String    @default("active")
  passwordHash String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

model AdminRolePermission {
  id         String   @id @default(cuid())
  role       String
  permission String
  createdAt  DateTime @default(now())

  @@unique([role, permission])
  @@map("admin_role_permissions")
}

// ───────────────────── Skill 40: legal entity / agreements / invoices ─────────────────────

model BusinessEntityProfile {
  id               String   @id @default(cuid())
  legalName        String
  displayName      String
  businessLicenseNo String?
