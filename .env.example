# Neon PostgreSQL 连接字符串
# 从 Neon 控制台获取，或通过 Vercel Neon Integration 自动注入
# DATABASE_URL 使用 pooled 连接（-pooler），用于应用运行时
# DIRECT_URL 使用直连，用于 Prisma migrations
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/scentpersona?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/scentpersona?sslmode=require"

# 管理后台 Basic Auth
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# 微信支付 (微信小程序 JSAPI 支付)
# 从微信支付商户平台获取
WECHAT_APPID="wx1234567890abcdef"
WECHAT_APP_SECRET="微信小程序 AppSecret"
WECHAT_MCHID="1234567890"
WECHAT_SERIAL_NO="商户证书序列号"
WECHAT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WECHAT_APIV3_KEY="APIv3密钥"
WECHAT_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
WECHAT_NOTIFY_URL="https://your-project.vercel.app/api/payment/wechat/notify"

# 小红书支付
# 从小红书开放平台获取
XHS_APP_ID="xhs_app_id"
XHS_APP_SECRET="xhs_app_secret"
XHS_MERCHANT_ID="xhs_merchant_id"
XHS_NOTIFY_URL="https://your-project.vercel.app/api/payment/xhs/notify"
