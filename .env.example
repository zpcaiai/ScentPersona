# ================================================================
# ScentPersona 环境变量示例
# 复制为 .env（本地）或逐条填入托管平台（Vercel 等）的环境变量。
# 约定：密钥只从环境变量读取，切勿入库；金额一律以「分」为单位。
# 分组与更详尽说明见 docs/DEPLOYMENT.md 第 3 节。
# 标 [必填] 的是最小可跑集合；其余按接入的渠道选填。
# ================================================================

# ----------------------------------------------------------------
# 1) 数据库（Neon PostgreSQL）  [必填]
# ----------------------------------------------------------------
# DATABASE_URL：连接池串，应用运行时用（带 ?sslmode=require）
# DIRECT_URL  ：直连串，prisma migrate / db seed 用
DATABASE_URL=
DIRECT_URL=

# ----------------------------------------------------------------
# 2) 站点与会话  [必填]
# ----------------------------------------------------------------
# APP_URL             ：站点公网地址，如 https://scentpersona.com（支付回跳/回调、二维码用）
# SESSION_SECRET      ：C 端用户会话签名密钥（随机 32+ 字节）
# ADMIN_SESSION_SECRET：后台会话 Cookie 的 HMAC 密钥（随机 32+ 字节，与上面不同）
APP_URL=
SESSION_SECRET=
ADMIN_SESSION_SECRET=

# ----------------------------------------------------------------
# 3) 后台账号
# ----------------------------------------------------------------
# ADMIN_BOOTSTRAP_EMAIL：首个后台 owner 账号邮箱（首次启动引导创建）  [必填]
# ADMIN_USERNAME / ADMIN_PASSWORD：旧版 Basic-Auth，已被 AdminUser + RBAC 取代，
#   仅作向后兼容/本地兜底；生产建议留空并使用 AdminUser 登录。
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ----------------------------------------------------------------
# 4) 支付 · 通用
# ----------------------------------------------------------------
# DEFAULT_PAYMENT_PROVIDER：mock | wechat | alipay | xhs（未接真实渠道时用 mock）
# MOCK_PAY_SECRET         ：mock 支付回调签名密钥（用 mock 时随便给个随机串）
DEFAULT_PAYMENT_PROVIDER=mock
MOCK_PAY_SECRET=

# ----------------------------------------------------------------
# 4a) 支付 · 微信支付 v3（接真实时填）
# 私钥是多行 PEM，粘贴时保留换行；只进环境变量，绝不入库。
# ----------------------------------------------------------------
WECHAT_APPID=
WECHAT_APP_SECRET=
WECHAT_MCHID=
WECHAT_SERIAL_NO=
WECHAT_PRIVATE_KEY=
WECHAT_APIV3_KEY=
WECHAT_PLATFORM_PUBLIC_KEY=
# 回调地址 = APP_URL + 微信回调路径，需在商户平台配置且公网可达
WECHAT_NOTIFY_URL=

# ----------------------------------------------------------------
# 4b) 支付 · 支付宝（接真实时填）
# ----------------------------------------------------------------
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# 生产网关：https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# ----------------------------------------------------------------
# 4c) 支付 · 小红书（接真实时填）
# ----------------------------------------------------------------
XHS_APP_ID=
XHS_APP_SECRET=
XHS_MERCHANT_ID=
XHS_NOTIFY_URL=

# ----------------------------------------------------------------
# 5) 物流 · 通用
# ----------------------------------------------------------------
# DEFAULT_SHIPPING_PROVIDER：manual（人工录入）| 具体物流 provider
DEFAULT_SHIPPING_PROVIDER=manual

# ----------------------------------------------------------------
# 6) 通知 · 邮件（Resend，选填；缺失则降级为站内消息）
# ----------------------------------------------------------------
RESEND_API_KEY=
# 发件地址，如 ScentPersona <noreply@scentpersona.com>
RESEND_FROM=

# ----------------------------------------------------------------
# 6a) 通知 · 短信（二选一，选填）
# ----------------------------------------------------------------
# 阿里云短信
ALIYUN_SMS_ACCESS_KEY_ID=
ALIYUN_SMS_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# 或 Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ----------------------------------------------------------------
# 6b) 通知 · 微信服务号模板消息（选填）
# 需先在服务号后台申请模板并让用户关注 + 绑定 openid
# ----------------------------------------------------------------
WECHAT_OA_APPID=
WECHAT_OA_SECRET=
WECHAT_OA_TEMPLATE_ID=

# ----------------------------------------------------------------
# 7) 电商平台开放接口（报价/比价，选填）
# 合规红线：仅用于价格展示与代下单；不保存用户账号密码、不代替登录、
# 不绕过登录/验证码/风控/反爬/限购、不自动抢购。缺失时对应平台走人工/种子数据。
# ----------------------------------------------------------------
# 京东
JD_APP_KEY=
JD_APP_SECRET=
JD_UNION_ID=
# 淘宝
TAOBAO_APP_KEY=
TAOBAO_APP_SECRET=
TAOBAO_SESSION=
# 天猫
TMALL_APP_KEY=
TMALL_APP_SECRET=
# 拼多多
PDD_CLIENT_ID=
PDD_CLIENT_SECRET=

# ----------------------------------------------------------------
# 8) 实时推送 · WebSocket（自托管时填；不填则前端自动用内置 SSE）
# ----------------------------------------------------------------
# WS_PORT          ：裸 WS 服务监听端口（scripts/ws-server.mjs / Dockerfile.ws）
# WS_PUBLISH_URL   ：Web 端向 WS 推送事件的地址
# WS_PUBLISH_SECRET：Web→WS 推送鉴权密钥
# NEXT_PUBLIC_WS_URL：浏览器连接地址，如 wss://ws.scentpersona.com（暴露到前端）
WS_PORT=8081
WS_PUBLISH_URL=
WS_PUBLISH_SECRET=
NEXT_PUBLIC_WS_URL=

# ----------------------------------------------------------------
# 9) 测试
# ----------------------------------------------------------------
# E2E_TEST=1 时开放受保护的测试播种接口（仅 CI/本地 E2E 使用，生产务必留空）
E2E_TEST=
