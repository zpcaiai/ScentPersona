# Neon PostgreSQL 连接字符串
# 从 Neon 控制台获取，或通过 Vercel Neon Integration 自动注入
# DATABASE_URL 使用 pooled 连接（-pooler），用于应用运行时
# DIRECT_URL 使用直连，用于 Prisma migrations
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/scentpersona?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/scentpersona?sslmode=require"

# 管理后台 Basic Auth
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me"

# 微信支付 (微信小程序 JSAPI 支付)
# 从微信支付商户平台获取
WECHAT_APPID="wx1234567890abcdef"
WECHAT_APP_SECRET="微信小程序 AppSecret"
WECHAT_MCHID="1234567890"
WECHAT_SERIAL_NO="商户证书序列号"
WECHAT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
WECHAT_APIV3_KEY="APIv3密钥"
WECHAT_PLATFORM_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
WECHAT_NOTIFY_URL="https://your-project.vercel.app/api/payment/wechat/notify"

# 小红书支付
# 从小红书开放平台获取
XHS_APP_ID="xhs_app_id"
XHS_APP_SECRET="xhs_app_secret"
XHS_MERCHANT_ID="xhs_merchant_id"
XHS_NOTIFY_URL="https://your-project.vercel.app/api/payment/xhs/notify"

# 授权商品数据源
# 只接入官方开放平台、联盟 API、品牌授权数据源或手动 CSV，不使用绕过登录/验证码/反爬的抓取。
JD_APP_KEY=""
JD_APP_SECRET=""
JD_UNION_ID=""
TAOBAO_APP_KEY=""
TAOBAO_APP_SECRET=""
TAOBAO_SESSION=""
TMALL_APP_KEY=""
TMALL_APP_SECRET=""
PDD_CLIENT_ID=""
PDD_CLIENT_SECRET=""

# ── 代下单 / 支付 / 物流 (proxy-order module) ──────────────────────
# 应用对外地址，用于支付成功/取消跳转
APP_URL="https://your-project.vercel.app"

# 支付：MVP 默认使用 mock provider（演示用，绝不真实扣款）。
# 生产环境改为 stripe / wechat / alipay，并配置对应密钥。
DEFAULT_PAYMENT_PROVIDER="mock"
MOCK_PAY_SECRET="change-me-mock-pay-secret"
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# ALIPAY_APP_ID=""
# ALIPAY_PRIVATE_KEY=""

# 物流：MVP 默认人工录入(manual)，可切换 mock 演示或接入 快递100/快递鸟。
DEFAULT_SHIPPING_PROVIDER="manual"
# KUAIDI100_KEY=""
# KUAIDI100_CUSTOMER=""
# KDNIAO_API_KEY=""
# KDNIAO_EBUSINESS_ID=""

# ── 用户账户会话 (Commercial Batch 1 / Skill 38) ──────────────────
# 用于签名登录态 cookie。生产环境务必改为强随机值。
SESSION_SECRET="change-me-session-secret"

# ── 后台管理员鉴权（AdminUser 升级版，替代 Basic-Auth） ──────────────
# 首次登录用 ADMIN_BOOTSTRAP_EMAIL（缺省回退 ADMIN_USERNAME）+ ADMIN_PASSWORD 自动创建 owner
ADMIN_BOOTSTRAP_EMAIL="admin@scentpersona.local"
ADMIN_SESSION_SECRET="change-me-admin-session-secret"

# ── 支付宝（真实支付） ────────────────────────────────────────────
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
ALIPAY_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
ALIPAY_GATEWAY="https://openapi.alipay.com/gateway.do"
ALIPAY_NOTIFY_URL="https://your-project.vercel.app/api/payments/webhook/alipay"
ALIPAY_RETURN_URL="https://your-project.vercel.app"

# ── 通知真实 provider（可选；未配置则回退站内/mock） ──────────────────
# 邮件：Resend
RESEND_API_KEY=""
RESEND_FROM="ScentPersona <noreply@your-domain.com>"
# 短信（中国）：阿里云（需预先申请签名与模板，模板变量名需与通知 data 键一致）
ALIYUN_SMS_ACCESS_KEY_ID=""
ALIYUN_SMS_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_TEMPLATE_CODE=""
# 短信（国际）：Twilio（内容自由）
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""

# ── 微信服务号模板消息（通知 wechat 渠道；收件人为用户 OA openid，经通知 data.openid 传入） ──
WECHAT_OA_APPID=""
WECHAT_OA_SECRET=""
WECHAT_OA_TEMPLATE_ID=""

# ── E2E 测试 ─────────────────────────────────────────────────────
# 置为 1 才启用 /api/test/seed-offer（Playwright 用），生产务必留空
E2E_TEST=""

# ── 裸 WebSocket 实时推送（自托管 Node，可选；不配则用 SSE） ──────────
# 独立 WS 服务(scripts/ws-server.mjs)监听端口与发布密钥
WS_PORT="3001"
WS_PUBLISH_SECRET=""
# Next 服务端调用 WS 服务发布事件的内网地址（如 http://127.0.0.1:3001）
WS_PUBLISH_URL=""
# 浏览器连接的公网 WS 地址（如 wss://ws.your-domain.com）；配置后 /pay/wechat 优先走 WS
NEXT_PUBLIC_WS_URL=""
